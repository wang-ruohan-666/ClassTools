          <property name="styleSheet">
           <string notr="true">QSlider::groove:horizontal {
    height: 6px;
    background: #e0e0e0;
    border-radius: 3px;
    margin: 2px 0;
}

QSlider::handle:horizontal {
    width: 16px;
    height: 16px;
    margin: -6px 0;
    background: #ffffff;
    border: 2px solid #c0c0c0;
    border-radius: 8px;
}

QSlider::handle:horizontal:hover {
    border-color: #888888;
}

QSlider::handle:horizontal:pressed {
    background: #f0f0f0;
    border-color: #555555;
}

QSlider::sub-page:horizontal {
    background: #448aff;
    border-radius: 3px;
}

QSlider::add-page:horizontal {
    background: #e0e0e0;
    border-radius: 3px;
}</string>
